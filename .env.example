# Kalike Asset Management — environment configuration.
# Copy this file to `.env` and fill in real values.
# `.env` is gitignored.

# Secret used to sign JWTs issued by /api/login.
# REQUIRED in production. Generate with:  openssl rand -base64 48
# If unset, the server falls back to a public dev secret and prints no warning.
JWT_SECRET=replace-me-with-a-long-random-string

# Port the Express API listens on. Default 3000.
# PORT=3000
